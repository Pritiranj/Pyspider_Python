     "text": [
      "Not Armstrong Number\n"
     ]
    }
   ],
   "source": [
    "num=15\n",
    "dup=num\n",
    "temp=num\n",
    "count=0\n",
    "res=0\n",
    "while num!=0:\n",
    "    num//=10\n",
    "    count+=1\n",
    "while dup!=0:\n",
    "    rem=dup%10\n",
    "    res=res + rem**count\n",
    "    dup//=10\n",
    "\n",
    "if temp==res:\n",
    "    print(\"Armstrong Number\")\n",
    "else:\n",
    "    print(\"Not Armstrong Number\")"
   ]
  },
