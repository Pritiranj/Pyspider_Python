    "from abc import ABC ,abstractmethod\n",
    "class tv(ABC):\n",
    "    @abstractmethod\n",
    "    def remote(self):\n",
    "        pass\n",
    "    def head(self):\n",
    "        print('hi')\n",
    "class ch1(tv):\n",
    "    def remote(self):\n",
    "        print('hi')\n",
    "obj=ch1()\n",
    "obj.remote()"
